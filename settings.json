{
    "editor.fontFamily": "'JetBrains Mono', 'Fira Code', monospace",
    "editor.fontLigatures": true,
    "editor.fontSize": 14,
    "editor.lineHeight": 22,
    "editor.fontWeight": "400",
    // ===== SYNTAX COLORS =====
    "editor.tokenColorCustomizations": {
        "comments": "#6A737D",
        "keywords": "#c91054",
        "functions": "#82AAFF",
        "variables": "#9CDCFE",
        // "strings": "#9bd840",
        "numbers": "#F78C6C",
        "types": "#FFCB6B",
        "textMateRules": [
            {
                "scope": [
                    "entity.name.function",
                ],
                "settings": {
                    "foreground": "#82AAFF",
                    "fontStyle": "bold"
                }
            },
            {
                "scope": "keyword",
                "settings": {
                    "foreground": "#c91054",
                    "fontStyle": "bold"
                }
            },
            {
                "scope": "variable",
                "settings": {
                    "foreground": "#f3ebeb",
                    "fontStyle": "bold"
                }
            },
            {
                "scope": "string",
                "settings": {
                    "foreground": "#8bcc28",
                    "fontStyle": "italic"
                }
            },
            {
                "scope": "comment",
                "settings": {
                    "foreground": "#a7afb8",
                    "fontStyle": "italic"
                }
            },
            {
                "scope": "storage.type.function.python",
                "settings": {
                    "foreground": "#c91054",
                    "fontStyle": "bold"
                }
            }
        ]
    },
    // ===== UI COLORS =====
    "workbench.colorCustomizations": {
        "editor.background": "#090a0c",
        "editor.foreground": "#D4D4D4",
        "editorLineNumber.foreground": "#5dd055",
        "editorLineNumber.activeForeground": "#C6C6C6",
        "editorCursor.foreground": "#AEAFAD",
        "editor.selectionBackground": "#2E3440",
        "editor.inactiveSelectionBackground": "#2E344080",
        "list.activeSelectionBackground": "#1F6F43",
        "list.activeSelectionForeground": "#ebf0ed",
        "list.inactiveSelectionBackground": "#164F33",
        "list.inactiveSelectionForeground": "#CFFFE5",
        "list.hoverBackground": "#123B27"
    },
    // ─── COMPACT LAYOUT (14" friendly) ───────────────────────────
    "window.zoomLevel": -0.0,
    // "editor.minimap.enabled": false,
    "editor.overviewRulerBorder": false,
    "editor.renderLineHighlight": "gutter",
    "workbench.tree.indent": 10, // slim sidebar tree
    // "workbench.tree.renderIndentGuides": "none",
    // ===== EDITOR =====
    "editor.cursorSmoothCaretAnimation": "on",
    "editor.cursorBlinking": "smooth",
    "editor.codeLens": false,
    "editor.scrollBeyondLastLine": false,
    "editor.wordWrap": "on",
    "editor.cursorStyle": "line",
    "editor.cursorWidth": 2,
    "editor.smoothScrolling": true,
    "editor.letterSpacing": 0.3,
    "editor.padding.top": 10, // frees left gutter space
    "breadcrumbs.enabled": false,
    "workbench.activityBar.location": "top",
    "python.analysis.typeCheckingMode": "basic",
    // "python.analysis.inlayHints.variableTypes": true,
    // "python.analysis.inlayHints.functionReturnTypes": true,
    // ─── MISC QUALITY ────────────────────────────────────────────
    "editor.inlineSuggest.enabled": true,
    "editor.suggest.preview": true,
    "files.autoSave": "afterDelay",
    "terminal.integrated.fontSize": 13,
    "terminal.integrated.fontFamily": "'JetBrains Mono'",
    "workbench.iconTheme": "material-icon-theme",
    "explorer.confirmDelete": false,
    "workbench.settings.applyToAllProfiles": [
    
    ],
    "explorer.confirmDragAndDrop": false,
    "files.exclude": {
        "**/__pycache__": true
    }
}